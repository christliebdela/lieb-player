{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lieb-Player",
  "version": "0.2.0",
  "identifier": "com.christlieb.liebplayer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Lieb Player",
        "width": 1280,
        "height": 720,
        "minWidth": 480,
        "minHeight": 270,
        "center": true,
        "transparent": true,
        "visible": false,
        "backgroundColor": "#000000",
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "publisher": "Christlieb Dela",
    "shortDescription": "Elite media experience powered by the Lieb Media Engine",
    "resources": [
      "mpv.exe",
      "yt-dlp.exe",
      "portable_config/**/*",
      "portable_config/scripts/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "headerImage": null,
        "sidebarImage": null,
        "installMode": "perMachine"
      }
    },
    "fileAssociations": [
      {
        "ext": ["mp4", "mkv", "avi", "mov", "webm", "m4v", "flv", "wmv", "3gp", "ts"],
        "name": "Video File",
        "description": "Video file handled by Lieb Player",
        "mimeType": "video/*",
        "role": "Viewer"
      },
      {
        "ext": ["mp3", "wav", "flac", "ogg", "m4a", "wma", "aac", "opus"],
        "name": "Audio File",
        "description": "Audio file handled by Lieb Player",
        "mimeType": "audio/*",
        "role": "Viewer"
      }
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/christliebdela/lieb-player/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMyMUJENEY5RjcyNzBDMzgKUldRNERDZjMrZFFiTW5xcmFtVDFhQzV6bWo2QzdEVGxETWk0UG5uNXRqK25HY21mMkJjL0J5SncK"
    }
  }
}
